{
  "session": {
    "provider": "ollama",
    "working_directory": "Populated at startup"
  },
  "providers": {
    "ollama": {
      "model": "qwen3-coder:30b",
      "opts": {
        "num_ctx": 16384,
        "temperature": 0.3
      }
    },
    "openai": {
      "model": "gpt-5.4-mini",
      "api_key": "sk-proj-nice-try-BYOK-im-afraid",
      "opts": {
        "temperature": 0.3
      }
    }
  },
  "interface": {
    "sidebar_open_on_start": true,
    "show_system_messages": true,
    "show_tool_messages": true
  },
  "prompts": {
    "system": "\nYou are Cody a highly skilled programming assistant.\n\nYou are currently working in the directory: {working_directory}\n"
  },
  "skills": {
    "directories": [
      "~/.agents/skills",
      "$CODY_DIR/skills",
      "{working_directory}/.agents/skills"
    ],
    "enabled": {
      "file-manipulation": true
    }
  },
  "commands": {
    "directories": [
      "$CODY_DIR/components/chat/cmd",
      "$CODY_DIR/cmd",
      "~/.agents/commands",
      "{working_directory}/.agents/commands"
    ]
  },
  "db": {
    "connections": []
  }
}
